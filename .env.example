# jota-speaker environment variables (prefix: JOTA_)

# TTS engine: "mock" (dev/CI) | "kokoro" (prod)
JOTA_ENGINE=mock

# Kokoro model files (only used when JOTA_ENGINE=kokoro)
# Download: https://github.com/thewh1teagle/kokoro-onnx/releases/tag/model-files-v1.0
JOTA_KOKORO_MODEL=/models/kokoro-v1.0.int8.onnx
JOTA_KOKORO_VOICES=/models/voices-v1.0.bin
JOTA_KOKORO_VOICE=af_heart
JOTA_KOKORO_LANG=en-us

# Audio settings
JOTA_SAMPLE_RATE=24000

# Accumulator: flush after this many chars even without a sentence boundary
JOTA_MIN_FLUSH_CHARS=80

# Auth provider: "stub" (dev/CI) | "jota_db" (prod)
JOTA_AUTH_PROVIDER=stub

# jota-db service (only used when JOTA_AUTH_PROVIDER=jota_db)
JOTA_JOTA_DB_URL=http://localhost:8001
JOTA_JOTA_DB_AUTH_PATH=/auth/validate
JOTA_JOTA_DB_TIMEOUT=5.0
